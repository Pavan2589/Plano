# CV Service Server Configuration
CV_PORT=8000

# PostgreSQL Configuration
# e.g., postgresql://postgres:your_password_here@localhost:5432/planogram_compliance
POSTGRES_URL=postgresql://postgres:your_password_here@localhost:5432/planogram_compliance

# YOLOv8 Configuration
YOLO_MODEL_PATH=models/shelf_detector.pt
YOLO_CONFIDENCE=0.25

# Gap Detection Threshold (ratio of shelf width, 0.05 = 5%)
GAP_THRESHOLD=0.05

# MinIO Object Storage Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
