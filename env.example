# ─── Backend (Node.js) ───────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=planogram_compliance
DB_USER=postgres
DB_PASSWORD=your_password_here

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_SHELF=shelf-images
MINIO_BUCKET_REFERENCE=reference-products
MINIO_BUCKET_ANNOTATED=annotated-results

# Python CV service (internal)
CV_SERVICE_URL=http://localhost:8000

# ─── CV Service (Python FastAPI) ────────────────────────────

# Server
CV_PORT=8000

# PostgreSQL (same DB)
CV_DB_HOST=localhost
CV_DB_PORT=5432
CV_DB_NAME=planogram_compliance
CV_DB_USER=postgres
CV_DB_PASSWORD=your_password_here

# MinIO (same instance)
CV_MINIO_ENDPOINT=localhost
CV_MINIO_PORT=9000
CV_MINIO_ACCESS_KEY=minioadmin
CV_MINIO_SECRET_KEY=minioadmin

# YOLO model path
YOLO_MODEL_PATH=models/shelf_detector.pt

# Embedding similarity threshold (below this = unknown product)
SIMILARITY_THRESHOLD=0.75

# Gap violation threshold (normalized, 0-1)
GAP_THRESHOLD=0.05

# ─── Frontend (Angular) ──────────────────────────────────────

# Set in environment.ts / environment.prod.ts
# API_BASE_URL=http://localhost:3000/api
