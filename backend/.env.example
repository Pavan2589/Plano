# Backend Server Configuration
PORT=3000

# PostgreSQL Configuration
# e.g., postgres://postgres:your_password_here@localhost:5432/planogram_compliance
DATABASE_URL=postgres://postgres:your_password_here@localhost:5433/planogram_compliance

# Redis Configuration (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secrets
JWT_ACCESS_SECRET=your_jwt_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars

# MinIO Object Storage Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# CV Service Microservice (internal address)
CV_SERVICE_URL=http://localhost:8000
